{
  "productName": "KRB Explorer",
  "version": "1.0.46",
  "identifier": "com.krb-explorer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KRB Explorer",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4RjdCMkU3REI1QjlERUMKUldUc25WdmI1N0wzT0FZU01WVHlSaXhRME9GRW90UlFRS2luL2EzazJGV3VWV3hhQjhUMnFpbGsK",
      "endpoints": [
        "https://github.com/krbxDev/krb-explorer/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "KRB Explorer",
    "copyright": "Copyright Â© 2025 Nova Explorer",
    "category": "Utility",
    "shortDescription": "A fast, modern Windows file manager",
    "longDescription": "Nova Explorer is a production-quality Windows file manager built with Tauri, featuring multi-tab browsing, split panes, instant search, file previews, git integration, archive browsing, bulk rename, and more.",
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  }
}